<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ECommerce</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/ECommerce.WebUI.styles.css"
          asp-append-version="true" />
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">

            <div class="container">

                <a class="navbar-brand fw-bold"
                   href="/Products">
                    ECommerce
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarContent">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">

                            <a class="nav-link text-dark"
                               href="/Products">

                                Ürünler

                            </a>

                        </li>

                        @if (Context.Session.GetString("UserRole") != "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Cart">Sepetim</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Orders">Siparişlerim</a>
                            </li>
                        }

                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/AdminOrders">
                                    Admin Siparişler
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/AdminProducts">
                                    Admin Stok
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/AdminCampaigns">
                                    Kampanyalar
                                </a>
                            </li>
                        }

                        @if (Context.Session.GetString("JWToken") != null)
                        {
                            <li class="nav-item">

                                <a class="nav-link text-danger"
                                   href="/Auth/Logout">

                                    Çıkış

                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container">

        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>

    <footer class="border-top footer text-muted mt-5">

        <div class="container py-3 text-center">

            © 2026 - ECommerce Project

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>