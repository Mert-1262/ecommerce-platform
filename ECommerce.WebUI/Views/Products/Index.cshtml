@model List<ECommerce.WebUI.Models.ProductModel>

@{
    var activeCampaign = ViewBag.ActiveCampaign as ECommerce.WebUI.Models.CampaignModel;
}

<div class="container mt-5">

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>Ürünler</h2>

        <a asp-controller="Cart" asp-action="Index" class="btn btn-dark">
            Sepetim
        </a>

    </div>

    @if (activeCampaign != null)
    {
        <div class="alert alert-dark py-2 mb-4" role="alert">
            <strong>@activeCampaign.Name</strong> %@activeCampaign.DiscountRate.ToString("N0")
        </div>
    }

    <form method="get"
          class="row mb-4">

        <div class="col-md-5">

            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Ürün ara..." />

        </div>

        <div class="col-md-4">

            <select name="categoryId"
                    class="form-select">

                <option value="">
                    Tüm Kategoriler
                </option>

                <option value="1">
                    Elektronik
                </option>

                <option value="2">
                    Giyim
                </option>

            </select>

        </div>

        <div class="col-md-3">

            <button type="submit"
                    class="btn btn-dark w-100">

                Ara

            </button>

        </div>

    </form>
    <div class="row">

        @foreach (var product in Model)
        {
            decimal? discountedPrice = null;

            if (activeCampaign != null)
            {
                discountedPrice = product.Price * (100 - activeCampaign.DiscountRate) / 100;
            }

            <div class="col-md-3 mb-4">

                <div class="card h-100 shadow-sm">

                    <img src="https://placehold.co/300x200"
                         class="card-img-top" />

                    <div class="card-body">

                        <h5 class="card-title">
                            @product.Name
                        </h5>

                        <p class="card-text text-muted">
                            @product.Description
                        </p>

                        <p>
                            Stok: @product.Stock
                        </p>

                        @if (discountedPrice.HasValue)
                        {
                            <div class="mb-2">
                                <div class="text-muted text-decoration-line-through">
                                    ₺@product.Price.ToString("N2")
                                </div>
                                <h5 class="text-danger mb-0">
                                    ₺@discountedPrice.Value.ToString("N2")
                                </h5>
                            </div>
                        }
                        else
                        {
                            <h5 class="text-dark">
                                ₺@product.Price.ToString("N2")
                            </h5>
                        }

                    </div>

                    <div class="card-footer bg-white border-0">

                        <form asp-controller="Products"
                              asp-action="AddToCart"
                              method="post"
                              class="m-0 product-add-form">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <label class="form-label small text-muted mb-1">Adet</label>
                            <div class="input-group input-group-sm mb-2">
                                <button type="button"
                                        class="btn btn-outline-secondary qty-minus"
                                        aria-label="Azalt">
                                    −
                                </button>
                                <input type="number"
                                       name="quantity"
                                       class="form-control text-center qty-input"
                                       value="1"
                                       min="1"
                                       max="@product.Stock"
                                       readonly />
                                <button type="button"
                                        class="btn btn-outline-secondary qty-plus"
                                        aria-label="Artır">
                                    +
                                </button>
                            </div>
                            <button type="submit" class="btn btn-dark w-100" @(product.Stock < 1 ? "disabled" : null)>
                                Sepete Ekle
                            </button>
                        </form>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

@section Scripts {
    <script>
        document.querySelectorAll('.product-add-form').forEach(function (form) {
            const input = form.querySelector('.qty-input');
            const min = parseInt(input.min, 10) || 1;
            const max = parseInt(input.max, 10) || min;

            form.querySelector('.qty-minus').addEventListener('click', function () {
                const value = parseInt(input.value, 10) || min;
                if (value > min) {
                    input.value = value - 1;
                }
            });

            form.querySelector('.qty-plus').addEventListener('click', function () {
                const value = parseInt(input.value, 10) || min;
                if (value < max) {
                    input.value = value + 1;
                }
            });
        });
    </script>
}